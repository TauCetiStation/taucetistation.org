{
  "name": "taucetistation",
  "main": "gulpfile.js",
  "browser": {
    "vue": "vue/dist/vue.common.js"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "babelify": "^10.0.0",
    "browserify": "^17.0.0",
    "postcss": "^8.4.39",
    "postcss-cli": "^11.0.0",
    "postcss-css-variables": "^0.19.0",
    "postcss-import": "^16.1.0",
    "postcss-nested": "^6.0.1",
    "postcss-url": "^10.1.3"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "moment": "^2.30.1",
    "moment-duration-format": "^2.3.2",
    "moment-timezone": "^0.5.45",
    "vue": "^3.0.0"
  },
  "postcss": {
    "plugins": {
      "postcss-import": {},
      "postcss-nested": {},
      "postcss-css-variables": {},
      "postcss-url": {
        "url": "inline",
        "basePath": "../.."
      }
    }
  },
  "browserify": {
    "transform": [
      [
        "babelify",
        {
          "presets": [
            "@babel/preset-env"
          ]
        }
      ]
    ]
  },
  "scripts": {
    "css": "postcss public/src/css/styles.css -o public/build/styles.css",
    "js": "browserify public/src/js/scripts.js -o public/build/scripts.js",
    "test": "browserify public/src/js/*.js -o public/build/scripts.js"
  }
}
